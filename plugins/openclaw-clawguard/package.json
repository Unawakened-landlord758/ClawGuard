{
  "name": "@clawguard/openclaw-clawguard",
  "version": "0.0.0-demo.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./openclaw.plugin.json"
  },
  "description": "Install-demo ClawGuard approval plugin for OpenClaw.",
  "license": "MIT",
  "keywords": [
    "clawguard",
    "openclaw",
    "plugin",
    "security",
    "approval"
  ],
  "files": [
    "src",
    "openclaw.plugin.json"
  ],
  "peerDependencies": {
    "clawguard": "^0.0.0",
    "openclaw": "^2026.3.9"
  },
  "openclaw": {
    "install": {
      "npmSpec": "@clawguard/openclaw-clawguard",
      "localPath": "plugins/openclaw-clawguard",
      "defaultChoice": "local"
    },
    "extensions": [
      "./src/index.ts"
    ]
  }
}
