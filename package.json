{
  "name": "clawguard",
  "version": "0.0.0",
  "private": true,
  "description": "Sprint 0 bootstrap for the future ClawGuard Node/TypeScript integration package.",
  "packageManager": "pnpm@10.4.1",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "site:dev": "pnpm --dir site dev",
    "site:build": "pnpm --dir site build",
    "site:preview": "pnpm --dir site preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "esbuild": "^0.25.10",
    "jiti": "^2.6.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
